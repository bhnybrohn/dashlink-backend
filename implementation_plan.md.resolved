## 3. Core Module — Shared Abstractions (DRY)

### 3.1 Base Model (all modules inherit)

```python
# app/core/base_model.py
class BaseModel(DeclarativeBase):
    id: Mapped[UUID] = mapped_column(primary_key=True, default=uuid4)
    created_at: Mapped[datetime] = mapped_column(default=func.now())
    updated_at: Mapped[datetime] = mapped_column(default=func.now(), onupdate=func.now())
    deleted_at: Mapped[datetime | None] = mapped_column(nullable=True)   # soft delete
    version: Mapped[int] = mapped_column(default=1)                      # optimistic locking
```

### 3.2 Base Repository (all repositories inherit)

```python
# app/core/base_repository.py
class BaseRepository(Generic[T]):
    """Generic CRUD — never duplicated across modules."""

    async def create(self, obj: T) -> T: ...
    async def get(self, id: UUID) -> T | None: ...
    async def get_or_404(self, id: UUID) -> T: ...
    async def list(self, filters, pagination) -> PaginatedResult[T]: ...
    async def update(self, id: UUID, data: dict) -> T: ...
    async def soft_delete(self, id: UUID) -> None: ...
```

### 3.3 Protocols (Dependency Inversion)

```python
# app/core/protocols.py
class PaymentGateway(Protocol):
    async def create_session(self, order: OrderData) -> SessionResult: ...
    async def verify_webhook(self, headers: dict, body: bytes) -> WebhookEvent: ...
    async def refund(self, payment_ref: str, amount: Decimal) -> RefundResult: ...

class NotificationChannel(Protocol):
    async def send(self, recipient: str, template: str, context: dict) -> DeliveryResult: ...

class StorageBackend(Protocol):
    async def upload(self, file: bytes, key: str, content_type: str) -> str: ...
    async def delete(self, key: str) -> None: ...
    def get_public_url(self, key: str) -> str: ...

class AIProvider(Protocol):
    async def generate_text(self, prompt: str, max_tokens: int) -> str: ...
    async def generate_image(self, prompt: str, size: str) -> bytes: ...
```

