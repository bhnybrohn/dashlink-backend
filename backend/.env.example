# ── Core ──
ENVIRONMENT=development
SECRET_KEY=change-me-to-a-256-bit-secret
DEBUG=true

# ── Database ──
DATABASE_URL=postgresql+asyncpg://dashlink:dashlink_dev@localhost:5432/dashlink
DATABASE_ECHO=false

# ── Redis ──
REDIS_URL=redis://localhost:6379/0

# ── JWT ──
JWT_ACCESS_TOKEN_EXPIRE_MINUTES=15
JWT_REFRESH_TOKEN_EXPIRE_DAYS=7
JWT_ALGORITHM=HS256

# ── Storage (S3/R2) ──
S3_BUCKET_NAME=dashlink-media
S3_ENDPOINT_URL=https://xxx.r2.cloudflarestorage.com
S3_ACCESS_KEY_ID=xxx
S3_SECRET_ACCESS_KEY=xxx
S3_REGION=auto

# ── Payment Gateways ──
STRIPE_SECRET_KEY=sk_test_xxx
STRIPE_WEBHOOK_SECRET=whsec_xxx
PAYSTACK_SECRET_KEY=sk_test_xxx
PAYSTACK_WEBHOOK_SECRET=xxx
FLUTTERWAVE_SECRET_KEY=xxx
FLUTTERWAVE_WEBHOOK_SECRET=xxx

# ── AI ──
OPENAI_API_KEY=sk-xxx
REMOVEBG_API_KEY=xxx

# ── Notifications ──
TWILIO_ACCOUNT_SID=xxx
TWILIO_AUTH_TOKEN=xxx
TWILIO_WHATSAPP_FROM=whatsapp:+14155238886
TWILIO_SMS_FROM=+1234567890
RESEND_API_KEY=re_xxx
RESEND_FROM_EMAIL=noreply@dashlink.to
FIREBASE_CREDENTIALS_PATH=./firebase-credentials.json

# ── Encryption ──
ENCRYPTION_KEY=change-me-32-byte-key-for-aes256

# ── CORS ──
CORS_ORIGINS=["http://localhost:3000","http://localhost:8080"]

# ── Rate Limiting ──
RATE_LIMIT_AUTH=5/15m
RATE_LIMIT_CHECKOUT=5/10m
RATE_LIMIT_GLOBAL=100/1m
